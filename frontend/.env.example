# Keycloak SSO (public client, PKCE — no secret)
# Leave blank to disable SSO; the frontend will fall back to GET /api/auth/keycloak/config
# (backend may serve config from server-side env so ops can flip SSO without rebuilding the SPA).
VITE_KEYCLOAK_URL=
VITE_KEYCLOAK_REALM=
VITE_KEYCLOAK_CLIENT_ID=
