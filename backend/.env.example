# Flask Configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-secrets.token_urlsafe-48-output-min-32-bytes
FLASK_DEBUG=True
FLASK_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/unichat

# JWT — must be >= 32 bytes for HS256 (RFC 7518). Generate same as SECRET_KEY above.
JWT_SECRET_KEY=replace-me-with-secrets.token_urlsafe-48-output-min-32-bytes

# OpenRouter API
OPENROUTER_API_KEY=your-openrouter-api-key

# Browser-Use Cloud API (https://browser-use.com)
BROWSER_USE_API_KEY=

# Default Admin Account (created on startup if set)
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# Optional: File Storage (for production use S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
