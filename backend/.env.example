# Flask Configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-secrets.token_urlsafe-48-output-min-32-bytes
FLASK_DEBUG=False
FLASK_ENV=production

# MongoDB
MONGO_URI=mongodb://localhost:27017/unichat

# min 32 chars; generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# OpenRouter API
OPENROUTER_API_KEY=your-openrouter-api-key

# Browser-Use Cloud API (https://browser-use.com)
# Optional
BROWSER_USE_API_KEY=

# Default Admin Account
# Optional. If set, password MUST be >= 16 chars and not in deny-list.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# Platform Operator (super-admin above CEO; lives in `platform_admins` collection, separate from `users`)
# Optional. If both EMAIL + PASSWORD are set, deploy script bootstraps one row via migrate_platform_admin.py.
# PASSWORD: min 12 chars, not in {admin,admin123,changeme,password,password123}. Create-only — never rotated by re-running.
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_NAME=Platform Operator

# comma-separated list of allowed origins. For single-host Flask serving SPA, this matches the public backend URL.
CORS_ORIGINS=http://YOUR-SERVER-IP:5000

# Scheduler (internal HTTP push)
SCHEDULER_BASE_URL=http://127.0.0.1:8082
# Shared secret for /internal/{reload,run-now}. MUST match scheduler's
# INTERNAL_TOKEN. Leave empty in single-tenant dev; required in prod.
SCHEDULER_INTERNAL_TOKEN=

# Telegram (used by frontend deep link)
TELEGRAM_BOT_USERNAME=

# ----- Server bind / ports -----
BACKEND_PORT=5000
BACKEND_BIND_HOST=0.0.0.0
GUNICORN_WORKERS=4
GUNICORN_THREADS=16

# Optional: File Storage (for production use S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# Meeting Assistant (Scribe v2 transcription)
ELEVENLABS_API_KEY=

# Keycloak SSO (optional; leave blank to disable SSO and run on local auth only)
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_EXPECTED_AUDIENCE=
